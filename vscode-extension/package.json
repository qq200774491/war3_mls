{
  "name": "war3-mls-tools",
  "displayName": "War3 MLS Tools",
  "description": "VSCode tools for local War3 MLS cloud-script simulation and multi-instance testing.",
  "version": "0.1.0",
  "publisher": "local",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:mls.startSimulator",
    "onCommand:mls.stopSimulator",
    "onCommand:mls.createRoom",
    "onCommand:mls.launchWar3Multi",
    "onCommand:mls.openDashboard",
    "onCommand:mls.sendEvent",
    "onCommand:mls.openDocs",
    "onCommand:mls.installBridgeFiles",
    "onCommand:mls.generateBridgeConfig"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mls.startSimulator",
        "title": "MLS: Start Simulator"
      },
      {
        "command": "mls.stopSimulator",
        "title": "MLS: Stop Simulator"
      },
      {
        "command": "mls.createRoom",
        "title": "MLS: Create Room"
      },
      {
        "command": "mls.launchWar3Multi",
        "title": "MLS: Launch War3 Multi Instance"
      },
      {
        "command": "mls.openDashboard",
        "title": "MLS: Open Dashboard"
      },
      {
        "command": "mls.sendEvent",
        "title": "MLS: Send Event"
      },
      {
        "command": "mls.openDocs",
        "title": "MLS: Open Docs"
      },
      {
        "command": "mls.installBridgeFiles",
        "title": "MLS: Install Bridge Files"
      },
      {
        "command": "mls.generateBridgeConfig",
        "title": "MLS: Generate Bridge Config"
      }
    ],
    "configuration": {
      "title": "War3 MLS Tools",
      "properties": {
        "mls.simulator.pythonPath": {
          "type": "string",
          "default": "python",
          "description": "Python executable used to run mls-sim."
        },
        "mls.simulator.host": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "Host address for mls-sim. Use 0.0.0.0 only for trusted LAN testing."
        },
        "mls.simulator.port": {
          "type": "number",
          "default": 5000,
          "description": "Local port for mls-sim."
        },
        "mls.script.defaultDir": {
          "type": "string",
          "default": "",
          "description": "Default MLS cloud script directory containing main.lua."
        },
        "mls.war3.exePath": {
          "type": "string",
          "default": "",
          "description": "War3 executable path."
        },
        "mls.war3.mapPath": {
          "type": "string",
          "default": "",
          "description": "Default War3 test map path."
        },
        "mls.war3.defaultPlayers": {
          "type": "number",
          "default": 2,
          "minimum": 1,
          "maximum": 12,
          "description": "Default number of local War3 instances."
        },
        "mls.war3.launchArgsTemplate": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "-loadfile",
            "${mapPath}"
          ],
          "description": "War3 launch argument template. Supports ${mapPath}, ${playerIndex}, ${roomId}."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.4.5"
  }
}
